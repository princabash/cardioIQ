{
  "version": 2,
  "rewrites": [
    {
      "source": "/.netlify/functions/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/generate-report.js": {
      "memory": 256,
      "maxDuration": 60
    }
  }
}
